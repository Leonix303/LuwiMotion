{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-features/main/tauri-v2-schema.json",
  "productName": "LuwiMotion",
  "version": "0.2.0",
  "identifier": "com.luwimotion.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LuwiMotion",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
